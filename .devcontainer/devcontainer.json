{
  "name": "ai-agent-sandbox (1C: platform + activation)",
  "dockerComposeFile": ["docker-compose.yml"],
  "service": "agent",
  "workspaceFolder": "/workspaces/work",
  "remoteUser": "vscode",
  "updateRemoteUserUID": false,
  "postCreateCommand": "bash /usr/local/share/agent-sandbox/postCreateCommand.sh && (bash /usr/local/share/agent-sandbox/sync-onec-infra-hosts.sh || bash .devcontainer/sync-onec-infra-hosts.sh || true) && sudo /usr/local/bin/onec-activate-community.sh",
  "postStartCommand": "bash /usr/local/share/agent-sandbox/postCreateCommand.sh && (bash /usr/local/share/agent-sandbox/sync-onec-infra-hosts.sh || bash .devcontainer/sync-onec-infra-hosts.sh || true) && sudo /usr/local/bin/onec-activate-community.sh",
  "remoteEnv": {
    "LANG": "ru_RU.UTF-8",
    "LANGUAGE": "ru_RU:ru",
    "LC_ALL": "ru_RU.UTF-8",
    "LC_CTYPE": "ru_RU.UTF-8"
  },
  "forwardPorts": [6080, 5900],
  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "22" }
  }
}
